{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OPC Theme",
  "description": "Visual theme definition for web pages. Tokens map directly to CSS custom properties.",
  "type": "object",
  "required": ["id", "name", "tokens"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "kebab-case identifier, used as data-theme attribute value"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 40,
      "description": "Display name for theme switcher"
    },
    "description": {
      "type": "string",
      "maxLength": 120,
      "description": "One-line description"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
      "maxItems": 8,
      "description": "Filterable tags: dark, light, corporate, playful, minimal, etc."
    },
    "source": {
      "type": "string",
      "enum": ["brand", "design-school", "mood", "custom", "variant"],
      "description": "Origin category of this theme"
    },
    "tokens": {
      "type": "object",
      "required": ["color", "typography", "shape"],
      "additionalProperties": false,
      "properties": {
        "color": {
          "type": "object",
          "required": ["bg", "bg-card", "text", "text-muted", "accent", "accent-light", "border", "correct-color", "correct-bg"],
          "additionalProperties": false,
          "properties": {
            "bg":                 { "type": "string", "description": "Page background" },
            "bg-card":            { "type": "string", "description": "Card background" },
            "text":               { "type": "string", "description": "Primary text color" },
            "text-muted":         { "type": "string", "description": "Secondary/muted text" },
            "accent":             { "type": "string", "description": "Primary accent color" },
            "accent-light":       { "type": "string", "description": "Light accent for backgrounds" },
            "accent-hover":       { "type": "string", "description": "Accent on hover state" },
            "border":             { "type": "string", "description": "Default border color" },
            "passage-bg":         { "type": "string", "description": "Reading passage background" },
            "passage-border":     { "type": "string", "description": "Reading passage border" },
            "correct-color":      { "type": "string", "description": "Correct answer highlight" },
            "correct-bg":         { "type": "string", "description": "Correct answer background" },
            "explanation-border": { "type": "string", "description": "Explanation block border" },
            "cat1": { "type": "string" },
            "cat2": { "type": "string" },
            "cat3": { "type": "string" },
            "cat4": { "type": "string" },
            "cat5": { "type": "string" },
            "cat6": { "type": "string" }
          }
        },
        "typography": {
          "type": "object",
          "required": ["heading-font", "body-font"],
          "additionalProperties": false,
          "properties": {
            "heading-font": { "type": "string", "description": "CSS font-family for headings" },
            "body-font":    { "type": "string", "description": "CSS font-family for body text" },
            "mono-font":    { "type": "string", "description": "CSS font-family for code/mono" }
          }
        },
        "shape": {
          "type": "object",
          "required": ["border-radius", "card-shadow"],
          "additionalProperties": false,
          "properties": {
            "border-radius": { "type": "string", "description": "Card border radius (CSS value)" },
            "card-shadow":   { "type": "string", "description": "Card box-shadow (CSS value or 'none')" }
          }
        }
      }
    },
    "effects": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["hover-lift", "glass-cards", "hard-shadow", "scanline-overlay", "gradient-bg", "subtle-transition", "glow-border", "paper-texture"]
      },
      "maxItems": 3,
      "description": "Pre-defined CSS effect classes to apply"
    },
    "google-fonts": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 4,
      "description": "Google Font family names to load"
    },
    "overrides": {
      "type": "string",
      "maxLength": 2000,
      "description": "Raw CSS overrides for this theme (optional)"
    }
  }
}
